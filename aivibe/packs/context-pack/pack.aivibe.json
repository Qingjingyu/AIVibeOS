{
  "name": "context-pack",
  "type": "pack",
  "purpose": "Load and stabilize the minimum project context before a task starts.",
  "inputs": [
    "project entry files",
    "current stage"
  ],
  "outputs": [
    "context file list",
    "resolved entrypoints"
  ],
  "lifecycle": "pre-task",
  "verification": [
    "required context files exist",
    "entrypoint list matches current project"
  ]
}

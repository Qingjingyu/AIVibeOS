{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AIVibe Decision Log",
  "type": "object",
  "required": ["id", "timestamp", "decision", "reason"],
  "properties": {
    "id": { "type": "string" },
    "timestamp": { "type": "string" },
    "decision": { "type": "string" },
    "reason": { "type": "string" },
    "affectedAreas": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
